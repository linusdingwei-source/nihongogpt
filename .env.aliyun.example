# ============================================
# 中国大陆版本 - 阿里云部署环境变量示例
# 复制为 .env 或 在 SAE/ECS 控制台配置
# ============================================

# ---------- 数据库（阿里云 RDS PostgreSQL）----------
# 连接池地址（应用直连）
DATABASE_URL="postgresql://用户名:密码@rm-xxxxx.pg.rds.aliyuncs.com:5432/数据库名"
# 直连地址（迁移/建表用，可选）
DIRECT_URL="postgresql://用户名:密码@rm-xxxxx.pg.rds.aliyuncs.com:5432/数据库名"

# ---------- 认证 ----------
AUTH_SECRET="随机生成的长字符串，可用 openssl rand -base64 32"
# 站点完整 URL，如 https://your-domain.com 或 SAE 分配的公网地址
NEXTAUTH_URL="https://你的域名或SAE公网地址"
# 若使用 Google 登录（大陆需代理或改用邮箱/手机）
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ---------- 云存储（阿里云 OSS，TTS 等文件）----------
STORAGE_PROVIDER=aliyun-oss
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=your-bucket-name
OSS_ACCESS_KEY_ID=你的AccessKeyId
OSS_ACCESS_KEY_SECRET=你的AccessKeySecret

# ---------- 大模型 / TTS（阿里云灵积 DashScope）----------
DASHSCOPE_API_KEY=你的DashScope API Key

# ---------- 邮件（可选，验证码等）----------
# RESEND 在大陆可能不稳定，可改用阿里云 DM 或 SMTP
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# ---------- 支付（可选）----------
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_ID_STARTER=
# STRIPE_PRICE_ID_PRO=
# STRIPE_PRICE_ID_PREMIUM=
# STRIPE_WEBHOOK_SECRET=

# ---------- 前端/SEO ----------
NEXT_PUBLIC_SITE_URL="https://你的域名"
