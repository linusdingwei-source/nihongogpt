# ============================================
# 中国大陆版本 - 阿里云部署环境变量示例
# 复制为 .env 或 在 SAE/ECS 控制台配置
# ============================================

# ---------- 数据库（阿里云 RDS PostgreSQL）----------
# 连接池地址（应用直连）
DATABASE_URL="postgresql://用户名:密码@rm-xxxxx.pg.rds.aliyuncs.com:5432/数据库名"
# 直连地址（迁移/建表用，可选）
DIRECT_URL="postgresql://用户名:密码@rm-xxxxx.pg.rds.aliyuncs.com:5432/数据库名"

# ---------- 认证 ----------
AUTH_SECRET="随机生成的长字符串，可用 openssl rand -base64 32"
# 站点完整 URL，如 https://your-domain.com 或 SAE 分配的公网地址
NEXTAUTH_URL="https://你的域名或SAE公网地址"
# 若使用 Google 登录（大陆需代理或改用邮箱/手机）
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ---------- 云存储（由 STORAGE_PROVIDER 控制，见 lib/storage-config.ts）----------
# 可选: vercel-blob | aliyun-oss | aws-s3 | cloudflare-r2
# 阿里云部署使用 aliyun-oss，并配置下方 OSS_* 即可
STORAGE_PROVIDER=aliyun-oss
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=your-bucket-name
# 可选：Bucket 下的固定目录，与其它应用共用同一 Bucket 时使用（如 nihongogpt），不设则存到 Bucket 根目录
OSS_PREFIX=nihongogpt
OSS_ACCESS_KEY_ID=你的AccessKeyId
OSS_ACCESS_KEY_SECRET=你的AccessKeySecret

# ---------- 大模型 / TTS（阿里云灵积 DashScope）----------
DASHSCOPE_API_KEY=你的DashScope API Key

# ---------- 邮件（可选，验证码等）----------
# RESEND 在大陆可能不稳定，可改用阿里云 DM 或 SMTP
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# ---------- 支付 ----------
# Stripe（国际信用卡，可选）
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_ID_STARTER=
# STRIPE_PRICE_ID_PRO=
# STRIPE_PRICE_ID_PREMIUM=
# STRIPE_WEBHOOK_SECRET=

# 支付宝（电脑网站支付，见 docs/PAYMENT_ALIPAY_WECHAT.md）
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# 微信支付 Native 扫码（见 docs/PAYMENT_ALIPAY_WECHAT.md）
# WECHAT_PAY_APP_ID=
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# WECHAT_PAY_PUBLIC_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# WECHAT_PAY_SERIAL_NO=
# WECHAT_PAY_API_V3_KEY=

# ---------- 前端/SEO ----------
NEXT_PUBLIC_SITE_URL="https://你的域名"
